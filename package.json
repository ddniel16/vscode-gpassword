{
  "name": "gpassword",
  "displayName": "gPassword",
  "description": "Password generator",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gpassword.Letters",
        "title": "Letters only",
        "category": "gPassword"
      },
      {
        "command": "gpassword.LettersNumbers",
        "title": "Letters and numbers",
        "category": "gPassword"
      },
      {
        "command": "gpassword.AllCharacters",
        "title": "Letters, Numbers & Symbols",
        "category": "gPassword"
      },
      {
        "command": "gpassword.passwordToBasicAuth",
        "description": "es una description",
        "title": "Replace password to hash of Basic Auth (bcrypt.hashSync)",
        "category": "gPassword"
      }
    ],
    "configuration": {
      "properties": {
        "gpassword.randomLengthMin": {
          "type": "integer",
          "default": 20,
          "description": "Minimum characters",
          "minimum": 15,
          "maximum": 54
        },
        "gpassword.randomLengthMax": {
          "type": "integer",
          "default": 25,
          "description": "Maximum characters",
          "minimum": 16,
          "maximum": 55
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "bcrypt": "^5.1.1"
  }
}
